    "max_font_size": 32
  },
  "edge": {
    "fontname": "Noto Serif CJK JP",
    "label": "ctf",
    "tooltip": ["ctf", "cdf", "cw", "z", "unit_ids"],
    "penwidth": 1.0,
    "length": 1.4
  }
