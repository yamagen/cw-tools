{
  "format": "dot",
  "filters": {
    "min_cw": null,
    "min_z": null
  },
  "dot": {
    "graph_name": "G",
    "directed": false,
    "charset": "UTF-8",
    "overlap": true,
    "outputorder": "edgesfirst",
    "fontname": "Noto Sans CJK JP",
    "--sep": "+8",
    "pack": true,
    "packmode": "graph",
    "-penwidth": 0.2,
    "style": "setlinewidth(.2)",
    "splines": "line"
  },
  "node": {
    "shape": "ellipse",
    "fontname": "Noto Sans CJK JP",
    "label_fields": [2],
    "label_separator": "/",
    "font_size_by": "fq",
    "--style": "setlinewidth(.2)",
    "penwidth": 0.2,
    "min_font_size": 6,
    "max_font_size": 18
  },
  "edge": {
    "fontname": "Noto Sans CJK JP",
    "--fontname": "Noto Serif CJK JP",
    "label": "ctf",
    "tooltip": ["ctf", "cdf", "cw", "z", "unit_ids"],
    "penwidth": 0.2,
    "length": 1.4
  }
}
