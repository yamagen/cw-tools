{
  "format": "dot",
  "filters": {
    "min_cw": null,
    "min_z": null
  },
  "dot": {
    "graph_name": "G",
    "directed": false,
    "charset": "UTF-8",
    "overlap": false,
    "outputorder": "edgesfirst"
  },
