{
  "format": "md",
  "filters": {
    "min_cw": null,
    "min_z": null
  },
  "table": {
    "columns": [
      "token1",
      "token2",
      "ctf",
      "cdf",
      "idf1",
      "idf2",
      "cw",
      "z",
      "unit_ids"
    ],
    "headers": [
      "Pattern 1",
      "Pattern 2",
      "CTF",
      "CDF",
      "IDF 1",
      "IDF 2",
      "CW",
      "Z",
      "Unit IDs"
    ],
    "label_fields": [1, 4],
    "label_separator": "/",
    "precision": 6,
    "unit_separator": ", ",
    "caption": "CW results",
    "label": "tab:cw-results"
  }
}
